# Copy to .env and adjust as needed.
#
# Leave MONGODB_URI empty to run a zero-config in-memory MongoDB
# (great for a quick local demo; data is reset on every restart).
#
# For a persistent database, point this at a local or Atlas instance, e.g.:
#   MONGODB_URI=mongodb://127.0.0.1:27017
#   MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_URI=
MONGODB_DB=ecommerce

# API server port
PORT=3000
